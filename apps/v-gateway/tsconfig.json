{
	"compilerOptions": {
		"module": "commonjs",
		"declaration": true,
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true,
		"allowSyntheticDefaultImports": true,
		"target": "esnext",
		"sourceMap": true,
		"outDir": "./dist",
		"baseUrl": "./",
		"ignoreDeprecations": "6.0",
		"incremental": true,
		"paths": {
			"@modules/*": [
				"src/modules/*"
			],
		}
	}
}