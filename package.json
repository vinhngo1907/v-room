{
  "name": "v-micro",
  "private": true,
  "workspaces": [
    "libs/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "build:lib": "turbo run build --filter=./libs/*",
    "lint": "turbo run lint",
    "lint-staged": "turbo run lint-staged"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "prettier": "~2.6.2",
    "pretty-quick": "^3.1.3",
    "turbo": "^1.2.4",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.1"
  },
  "dependencies": {
    "tsconfig-paths": "^4.2.0"
  }
}